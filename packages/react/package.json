{
  "name": "@kussetsu/react",
  "version": "0.1.0",
  "description": "React binding for Kussetsu: <GlassScene>/<GlassPanel> components and a useShader hook for refractive WGSL glass UI.",
  "type": "module",
  "license": "MIT",
  "author": "Stephen Horton",
  "homepage": "https://github.com/StephenSHorton/kussetsu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StephenSHorton/kussetsu.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/StephenSHorton/kussetsu/issues",
  "keywords": [
    "react",
    "webgpu",
    "wgsl",
    "shader",
    "glass",
    "glassmorphism",
    "ui"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@kussetsu/core": "0.1.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3"
  },
  "sideEffects": false
}
