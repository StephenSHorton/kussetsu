{
  "name": "kussetsu",
  "version": "0.1.0",
  "description": "R3F for 2D UI — React-authored interface painted entirely on the GPU (WebGPU/WGSL), with the DOM as an invisible accessibility + input layer.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "test": "node test/compat.test.mjs",
    "prepublishOnly": "npm run build:lib"
  },
  "keywords": [
    "webgpu",
    "wgsl",
    "react",
    "react-reconciler",
    "react-three-fiber",
    "r3f",
    "renderer",
    "ui",
    "webgpu-ui",
    "gpu",
    "glass",
    "glassmorphism",
    "shaders"
  ],
  "author": "Stephen Horton",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StephenSHorton/kussetsu.git"
  },
  "bugs": {
    "url": "https://github.com/StephenSHorton/kussetsu/issues"
  },
  "homepage": "https://stephenshorton.github.io/kussetsu/",
  "peerDependencies": {
    "react": "^18.2.0"
  },
  "dependencies": {
    "react-reconciler": "^0.29.2",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@types/react": "^18.3.31",
    "@types/react-reconciler": "^0.33.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@webgpu/types": "^0.1.70",
    "react": "^18.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
